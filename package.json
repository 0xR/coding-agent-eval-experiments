{
  "name": "coding-agent-eval-experiments",
  "version": "1.0.0",
  "private": true,
  "description": "Promptfoo evaluations for coding agents, including a PR code-review eval.",
  "scripts": {
    "eval": "PROMPTFOO_CONFIG_DIR=.promptfoo PROMPTFOO_DISABLE_TELEMETRY=true promptfoo eval -c promptfooconfig.yaml --no-cache --no-share",
    "setup:review": "bash scripts/setup-review-repo.sh",
    "eval:review": "PROMPTFOO_CONFIG_DIR=.promptfoo PROMPTFOO_DISABLE_TELEMETRY=true promptfoo eval -c promptfooconfig.review.yaml --env-file .env --no-cache --no-share",
    "view": "PROMPTFOO_CONFIG_DIR=.promptfoo promptfoo view -y",
    "test:unit": "node --test \"src/*.test.js\"",
    "test": "npm run eval"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.211",
    "@openai/codex-sdk": "^0.144.5",
    "promptfoo": "^0.120.19"
  }
}
